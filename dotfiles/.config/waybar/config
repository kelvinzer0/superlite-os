{
    "layer": "top",
    "position": "bottom",
    "height": 32,
    "margin": "0 8 8 8",
    "spacing": 8,

    "modules-left": ["wlr/taskbar"],
    "modules-center": [],
    "modules-right": ["custom/search", "clock", "network", "battery"],

    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 16,
        "icon-theme": "Haiku",
        "on-click": "minimize-raise",
        "on-click-middle": "close",
        "rewrite": {
            "Firefox": "",
            "Foot": "Terminal",
            "File Manager PCManFM": "Files",
            "Code - OSS - URL Handler": "Code",
            "Telegram Desktop": "Telegram",
            "mpv Media Player": "mpv",
            "GNU Image Manipulation Program": "GIMP",
            "Inkscape Vector Graphics Editor": "Inkscape",
            "Thunderbird": "Mail"
        }
    },

    "custom/search": {
        "format": " Search",
        "on-click": "$HOME/.config/scripts/file-search.sh",
        "tooltip": false
    },

    "clock": {
        "format": "{:%a %d %b, %H:%M}",
        "tooltip": false
    },

    "network": {
        "format-wifi": "{signalStrength}%",
        "format-ethernet": "",
        "format-disconnected": "Offline",
        "tooltip-format": "{essid} [{signalStrength}%]",
        "on-click-right": "foot sudo nmtui",
        "on-click": "sudo nmcli networking connectivity | grep -q none && sudo nmcli networking on && notify-send 'Wi-Fi On' || sudo nmcli networking off"
    },

    "battery": {
        "bat": "BAT0",
        "adapter": "ADP1",
        "full-at": 100,
        "interval": 30,
        "states": {
            "warning": 15,
            "critical": 5
        },
        "format": "{capacity}%",
        "format-charging": "+{capacity}%",
        "format-plugged": "+{capacity}%",
        "tooltip-format": "{capacity}% ({timeTo})"
    },
    "battery#bat2": {
        "bat": "BAT1",
        "adapter": "ADP1",
        "full-at": 100,
        "interval": 30
    }
}
