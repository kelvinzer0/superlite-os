<?xml version="1.0"?>
<labwc_config>
  <core>
    <decoration>server</decoration>
    <gap>4</gap>
    <adaptiveSync>no</adaptiveSync>
    <allowTearing>no</allowTearing>
  </core>
  <theme>
    <name>Adwaita</name>
    <font place="ActiveWindow">
      <name>JetBrains Mono</name>
      <size>10</size>
    </font>
    <font place="InactiveWindow">
      <name>JetBrains Mono</name>
      <size>10</size>
    </font>
    <font place="MenuHeader">
      <name>JetBrains Mono</name>
      <size>10</size>
    </font>
    <font place="Osd">
      <name>JetBrains Mono</name>
      <size>10</size>
    </font>
  </theme>
  <keyboard>
    <keybind key="A-Return">
      <action name="ToggleMaximize"/>
    </keybind>
    <keybind key="A-F4">
      <action name="Close"/>
    </keybind>
    <keybind key="A-Tab">
      <action name="NextWindow"/>
    </keybind>
    <keybind key="A-S-Tab">
      <action name="PreviousWindow"/>
    </keybind>
    <keybind key="W-Return">
      <action name="Execute">
        <command>foot</command>
      </action>
    </keybind>
    <keybind key="W-d">
      <action name="Execute">
        <command>tofi-run | sh</command>
      </action>
    </keybind>
    <keybind key="W-e">
      <action name="Execute">
        <command>pcmanfm</command>
      </action>
    </keybind>
    <keybind key="W-q">
      <action name="Close"/>
    </keybind>
    <keybind key="W-f">
      <action name="ToggleMaximize"/>
    </keybind>
    <keybind key="W-m">
      <action name="Iconify"/>
    </keybind>
    <keybind key="A-Space">
      <action name="ToggleFloating"/>
    </keybind>
    <keybind key="W-1">
      <action name="GoToDesktop" to="1"/>
    </keybind>
    <keybind key="W-2">
      <action name="GoToDesktop" to="2"/>
    </keybind>
    <keybind key="W-3">
      <action name="GoToDesktop" to="3"/>
    </keybind>
    <keybind key="W-4">
      <action name="GoToDesktop" to="4"/>
    </keybind>
    <keybind key="W-l">
      <action name="Execute">
        <command>swaylock -c 0f0f23</command>
      </action>
    </keybind>
    <keybind key="Print">
      <action name="Execute">
        <command>grim ~/Pictures/screenshot-$(date +%Y%m%d-%H%M%S).png</command>
      </action>
    </keybind>
    <keybind key="A-Print">
      <action name="Execute">
        <command>grim -g "$(slurp)" ~/Pictures/screenshot-$(date +%Y%m%d-%H%M%S).png</command>
      </action>
    </keybind>
  </keyboard>
  <mouse>
    <default>
      <context name="Frame">
        <mousebind button="A-Left" action="Press">
          <action name="Focus"/>
          <action name="Raise"/>
        </mousebind>
        <mousebind button="A-Left" action="Drag">
          <action name="Move"/>
        </mousebind>
        <mousebind button="A-Right" action="Drag">
          <action name="Resize"/>
        </mousebind>
      </context>
      <context name="Root">
        <mousebind button="Right" action="Press">
          <action name="ShowMenu">
            <menu>root-menu</menu>
          </action>
        </mousebind>
      </context>
    </default>
  </mouse>
  <windowRules/>
</labwc_config>
