#!/bin/sh
# SuperLite OS — LabWC autostart
# Minimal: only what's actually installed

# Background color (no swaybg — not installed)
# LabWC uses solid color from environment

# Brightness
brightnessctl set 80% 2>/dev/null &

# GTK theme
gsettings set org.gnome.desktop.interface gtk-theme 'Adwaita' 2>/dev/null &
gsettings set org.gnome.desktop.interface font-name 'DejaVu Sans 9' 2>/dev/null &
