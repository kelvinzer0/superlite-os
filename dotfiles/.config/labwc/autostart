# LabWC autostart file
# SuperLite OS — autostart services on session launch

# Wallpaper — use wpaperd for random rotation, fallback to swaybg
DEFAULT_WP="$HOME/Pictures/wallpapers/default.png"
if [ -d "$HOME/Pictures/wallpapers" ] && ls "$HOME/Pictures/wallpapers"/*.{jpg,png,webp} >/dev/null 2>&1; then
    # Count wallpapers — use wpaperd if multiple, swaybg if single
    WP_COUNT=$(ls "$HOME/Pictures/wallpapers"/*.{jpg,png,webp} 2>/dev/null | wc -l)
    if [ "$WP_COUNT" -gt 1 ] && command -v wpaperd >/dev/null 2>&1; then
        wpaperd >/dev/null 2>&1 &
    else
        # Single wallpaper or wpaperd not available
        WP=$(ls "$HOME/Pictures/wallpapers"/*.{jpg,png,webp} 2>/dev/null | shuf -n1)
        swaybg -i "$WP" -m fill >/dev/null 2>&1 &
    fi
elif [ -f "$DEFAULT_WP" ]; then
    swaybg -i "$DEFAULT_WP" -m fill >/dev/null 2>&1 &
fi

waybar >/dev/null 2>&1 &
mako >/dev/null 2>&1 &
gammastep -O 5600 2>&1 &
swayidle -w timeout 600 'sudo zzz' 2>&1 &
brightnessctl set 80% 2>&1 &

/usr/libexec/pipewire-launcher 2>&1 &
#udiskie 2>&1 &

gsettings set org.gnome.desktop.interface gtk-theme 'WhiteSur-Light' 2>&1 &
gsettings set org.gnome.desktop.interface font-name 'JetBrains Mono 10' 2>&1 &
gsettings set org.gnome.desktop.interface icon-theme 'SuperLite' 2>&1 &
gsettings set org.gnome.desktop.interface cursor-theme 'simp1e-cursors' 2>&1 &
