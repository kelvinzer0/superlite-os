<?xml version="1.0" encoding="UTF-8"?>
<openbox_menu>
<menu id="root-menu" label="root-menu">
		<item label="Logout">
			<action name="Execute"><command>labwc --exit</command></action>
		</item>
		<item label="Suspend">
			<action name="Execute"><command>sudo zzz</command></action>
		</item>
		<item label="Restart">
			<action name="Execute"><command>sudo reboot -i</command></action>
		</item>
		<item label="Shutdown">
			<action name="Execute"><command>sudo poweroff</command></action>
		</item>
	<separator/>
	<menu id="Power" label="Tool">
		<item label="File">
			<action name="Execute"><command>thunar</command></action>
		</item>
		<item label="E-Mail">
			<action name="Execute"><command>thunderbird</command></action>
		</item>
		<item label="Browser">
			<action name="Execute"><command>firefox</command></action>
		</item>
		<item label="Terminal">
			<action name="Execute"><command>foot</command></action>
		</item>
	</menu>
 <!-- Other -->
		<separator/>

	<menu id="Display" label="Display">
		<item label="Auto (Native)">
			<action name="Execute"><command>wlr-randr --output eDP-1 --preferred</command></action>
		</item>
		<separator/>
		<item label="1920x1080">
			<action name="Execute"><command>wlr-randr --output eDP-1 --mode 1920x1080@60</command></action>
		</item>
		<item label="1600x900">
			<action name="Execute"><command>wlr-randr --output eDP-1 --mode 1600x900@60</command></action>
		</item>
		<item label="1366x768">
			<action name="Execute"><command>wlr-randr --output eDP-1 --mode 1366x768@60</command></action>
		</item>
		<item label="1280x720">
			<action name="Execute"><command>wlr-randr --output eDP-1 --mode 1280x720@60</command></action>
		</item>
		<separator/>
		<item label="Show Current">
			<action name="Execute"><command>foot -e sh -c "wlr-randr; echo; read -p 'Press Enter to close'"</command></action>
		</item>
	</menu>

	<menu id="Wallpaper" label="Wallpaper">
		<item label="Browse...">
			<action name="Execute"><command>thunar ~/Pictures/wallpapers</command></action>
		</item>
		<separator/>
		<item label="Default Wallpaper">
			<action name="Execute"><command>sh -c "pkill swaybg; swaybg -i ~/Pictures/wallpapers/default.png -m fill &amp;"</command></action>
		</item>
		<item label="Random Wallpaper">
			<action name="Execute"><command>sh -c "pkill swaybg; f=$(ls ~/Pictures/wallpapers/*.jpg ~/Pictures/wallpapers/*.png ~/Pictures/wallpapers/*.webp 2>/dev/null | shuf -n1); [ -n \"$f\" ] &amp;&amp; swaybg -i \"$f\" -m fill &amp;"</command></action>
		</item>
		<separator/>
		<item label="Stop Wallpaper">
			<action name="Execute"><command>pkill swaybg</command></action>
		</item>
		<separator/>
		<item label="Fetch Wallpapers...">
			<action name="Execute"><command>foot -e sh -c "$HOME/.config/scripts/wallpaper-fetch.sh 5; echo; read -p 'Press Enter to close'"</command></action>
		</item>
	</menu>

	<menu id="Vpn" label="VPN">
	<item label="Connect">
		<action name="Execute"><command>wg-quick up wgcf-profile</command></action>
	</item>
	<item label="Disconnect">
		<action name="Execute"><command>wg-quick down wgcf-profile</command></action>
	</item>
	<item label="Register WARP">
		<action name="Execute"><command>foot -e sh -c "wgcf register; wgcf generate; echo Done; read"</command></action>
	</item>
	</menu>
</menu> <!-- root-menu -->
</openbox_menu>
