# ============================================================================
# SuperLite OS — Package List (LabWC-Alpine-Netbook Style)
# Minimal desktop with RiccardoPP's aesthetic. No bloat.
# ============================================================================
# NOTE: Use ONLY confirmed Alpine edge package names.
# Invalid names will cause apk to fail the ENTIRE batch.

# --- Base ---
alpine-base
openrc
busybox
busybox-suid

# --- Kernel + Targeted Firmware ---
linux-lts
linux-firmware-i915
linux-firmware-amdgpu
linux-firmware-amd-ucode
linux-firmware-ath10k
linux-firmware-rtlwifi
linux-firmware-rtw89
linux-firmware-rtl_bt
linux-firmware-brcm
linux-firmware-cirrus
linux-firmware-other

# --- Wayland Desktop ---
labwc
foot
mesa-dri-gallium
mesa-egl
mesa-gl
mesa-gbm
seatd
dbus

# --- Desktop Components (LabWC-Alpine-Netbook style) ---
waybar
swaybg
swayidle
mako
tofi
gammastep
brightnessctl
gsettings-desktop-schemas

# --- Fonts & Cursors ---
font-awesome
font-terminus
simp1e-cursors

# --- Networking ---
networkmanager

# --- Boot (ISO only, not runtime) ---
grub-efi
grub-bios
syslinux
squashfs-tools
xorriso
mkinitfs
mtools
dosfstools
lua5.4
