#!/bin/sh
# ============================================================================
# SuperLite OS — mkinitfs feature hook
# Registers live-boot support in the initramfs
# ============================================================================
# This hook is installed as a mkinitfs feature.
# It ensures the live-boot init script is included in the initramfs.
# ============================================================================

# Feature: superlite-live
# Adds live-boot support with squashfs overlay to initramfs

# Required kernel modules (expanded set for better hardware coverage)
for mod in \
    isofs squashfs loop overlay \
    usb-storage usb_storage \
    sd_mod sr_mod mmc_block \
    nvme nvme_core \
    vfat fat msdos \
    nls_cp437 nls_iso8859_1 nls_ascii \
    usbhid xhci_hcd ehci_hcd ohci_hcd uhci_hcd \
    scsi_mod usb_common \
    ext4 jbd2 crc16; do
    echo "$mod"
done > "${DESTDIR:-/}/etc/modules" 2>/dev/null || true

# Install the live-boot init script
if [ -f /tmp/hooks/superlite-live.init ]; then
    install -D -m 0755 /tmp/hooks/superlite-live.init "${DESTDIR:-/}/init"
    # Also install as /sbin/init.live for compatibility
    install -D -m 0755 /tmp/hooks/superlite-live.init "${DESTDIR:-/}/sbin/init.live"
fi

# Include required binaries in initramfs
# PRIORITY: Always prefer Alpine rootfs binaries over host (Ubuntu) binaries.
# Host modprobe/kmod may not work with Alpine's module format.
for bin in switch_root mount umount modprobe insmod depmod sleep mkdir ls cat mountpoint \
           setsid mdev udevd udevadm blkid findmnt; do
    binpath=""
    # First: try Alpine rootfs (most reliable for module loading)
    for rootfs_path in \
        "${ROOTFS:-/}/sbin/$bin" \
        "${ROOTFS:-/}/bin/$bin" \
        "${ROOTFS:-/}/usr/sbin/$bin" \
        "${ROOTFS:-/}/usr/bin/$bin"; do
        [ -f "$rootfs_path" ] && binpath="$rootfs_path" && break
    done
    # Fallback: host system (for tools not in rootfs)
    if [ -z "$binpath" ]; then
        binpath=$(command -v "$bin" 2>/dev/null)
    fi
    if [ -n "$binpath" ] && [ -f "$binpath" ]; then
        install -D -m 0755 "$binpath" "${DESTDIR:-/}/bin/$bin" 2>/dev/null || true
    fi
done

# Ensure /bin/sh exists (busybox symlink)
if [ ! -e "${DESTDIR:-/}/bin/sh" ]; then
    if [ -e "${DESTDIR:-/}/bin/busybox" ]; then
        ln -sf busybox "${DESTDIR:-/}/bin/sh" 2>/dev/null || true
    fi
fi

# Install essential device nodes for emergency shell
# (devpts needs /dev/pts mountpoint, console needs to exist)
mkdir -p "${DESTDIR:-/}/dev/pts" "${DESTDIR:-/}/dev/shm" 2>/dev/null || true
